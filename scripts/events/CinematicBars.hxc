import flixel.tweens.FlxTween;
import flixel.FlxCamera;
import flixel.tweens.FlxEase;
import flixel.FlxG;
import funkin.Conductor;
import funkin.play.PlayState;
import funkin.play.event.ScriptedSongEvent;
import Std;

class CinematicBars extends ScriptedSongEvent {

    public function new() {
        super('CinematicBars');
    }

    public override function handleEvent(data):Void {

    }

    public override function getTitle():String {
        return "Cinematic Bars";
    }

    public override function getEventSchema() {
        return ([
            {
				name: "tweenBars",
				title: "Tween Bars?",
				type: "bool",
				defaultValue: true,
			},
			{
                name: 'size',
                title: 'New Size',
                defaultValue: 0.2,
                step: 0.25,
                type: 'float',
                units: 'steps'
            },
			{
                name: 'time',
                title: 'Tween Time (Steps)',
                defaultValue: 4.0,
                step: 0.25,
                type: 'float',
                units: 'steps'
            },
            {
                name: 'hexColor',
                title: 'Hex Color',
                defaultValue: "000000",
                type: 'string'
            },
            {
				// keys taken from focus camera event
                name: "tweenEase",
                title: "Tween Ease",
                defaultValue: "linear",
                type: "enum",
                keys: [
				  'Linear' => 'linear',
				  'Sine In' => 'sineIn',
				  'Sine Out' => 'sineOut',
				  'Sine In/Out' => 'sineInOut',
				  'Quad In' => 'quadIn',
				  'Quad Out' => 'quadOut',
				  'Quad In/Out' => 'quadInOut',
				  'Cube In' => 'cubeIn',
				  'Cube Out' => 'cubeOut',
				  'Cube In/Out' => 'cubeInOut',
				  'Quart In' => 'quartIn',
				  'Quart Out' => 'quartOut',
				  'Quart In/Out' => 'quartInOut',
				  'Quint In' => 'quintIn',
				  'Quint Out' => 'quintOut',
				  'Quint In/Out' => 'quintInOut',
				  'Expo In' => 'expoIn',
				  'Expo Out' => 'expoOut',
				  'Expo In/Out' => 'expoInOut',
				  'Smooth Step In' => 'smoothStepIn',
				  'Smooth Step Out' => 'smoothStepOut',
				  'Smooth Step In/Out' => 'smoothStepInOut',
				  'Smoother Step In' => 'smootherStepIn',
				  'Smoother Step Out' => 'smootherStepOut',
				  'Smoother Step In/Out' => 'smootherStepInOut',
				  'Elastic In' => 'elasticIn',
				  'Elastic Out' => 'elasticOut',
				  'Elastic In/Out' => 'elasticInOut',
				  'Back In' => 'backIn',
				  'Back Out' => 'backOut',
				  'Back In/Out' => 'backInOut',
				  'Bounce In' => 'bounceIn',
				  'Bounce Out' => 'bounceOut',
				  'Bounce In/Out' => 'bounceInOut',
				  'Circ In' => 'circIn',
				  'Circ Out' => 'circOut',
				  'Circ In/Out' => 'circInOut'
				]
            }
        ]);
    }
}
